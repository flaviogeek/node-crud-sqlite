# =========================
# 🔹 Default: texto em LF (Linux)
# =========================
* text=auto eol=lf

# =========================
# 🔹 Scripts (CRÍTICO)
# =========================
*.sh text eol=lf
*.bash text eol=lf

# =========================
# 🔹 Node / JS / Config
# =========================
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# =========================
# 🔹 Docker
# =========================
Dockerfile text eol=lf
docker-compose.yml text eol=lf
.dockerignore text eol=lf

# =========================
# 🔹 Shell / Env
# =========================
.env text eol=lf
.env.* text eol=lf

# =========================
# 🔹 Windows scripts (se existir)
# =========================
*.bat text eol=crlf
*.cmd text eol=crlf

# =========================
# 🔹 Binários (não alterar)
# =========================
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.sqlite binary
*.db binary

# =========================
# 🔹 Git configs importantes
# =========================
*.md text eol=lf